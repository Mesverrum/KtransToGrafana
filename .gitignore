# Local secrets and runtime state — never commit.
.env
config.alloy

# Generator inputs with real credentials (templates are in groups/*.env.sample).
groups/*.env
!groups/*.env.sample

# Generator outputs (re-created by scripts/generate-groups.sh).
config/*.yaml
compose-groups.generated.yaml

# Discovery runtime artifacts (written by scripts/run-discovery.sh).
state/*.yaml
!state/.gitkeep
