OTEL_SERVICE_NAME=ktranslate
OTEL_EXPORTER_OTLP_COMPRESSION=gzip
NF_SOURCE=auto
GC_OTLP_URL=https://foo/otlp
GC_OTLP_ACCOUNT=0000000
GC_OTLP_KEY=glc_foo
SYSLOG_SOURCE=0.0.0.0:1514

# NetBox is the source of truth for which devices each group polls. The
# discovery container reads ${NETBOX_HOST} and ${NETBOX_TOKEN} at runtime and
# queries NetBox using the per-group filters in groups/<name>.env.
NETBOX_HOST=https://netbox.example.com
NETBOX_TOKEN=replace_me_netbox_api_token
