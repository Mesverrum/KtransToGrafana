# One credential group. Copy this file to groups/<name>.env (without .sample),
# edit the values, then run ./scripts/generate-groups.sh to render configs.
#
# GROUP must be unique across all files in groups/. Ports must be unique
# across groups AND must not collide with the static services in
# compose-base.yaml (flow/syslog/alloy use 9995, 9996, 9998, 4317, 12346,
# 1514).

GROUP=cisco

# SNMP version this group uses. Either "v2c" or "v3".
SNMP_VERSION=v3

# v3 credentials (used when SNMP_VERSION=v3, ignored otherwise).
SNMP_V3_USER=cisco_snmp_user
SNMP_V3_AUTH_PROTOCOL=SHA
SNMP_V3_AUTH_PASS=REPLACE_ME_CISCO_AUTH
SNMP_V3_PRIV_PROTOCOL=AES
SNMP_V3_PRIV_PASS=REPLACE_ME_CISCO_PRIV

# v2c community (used when SNMP_VERSION=v2c, ignored otherwise).
SNMP_V2_COMMUNITY=

# Community string applied to incoming SNMP traps for this group.
TRAP_COMMUNITY=cisco_trap_string

# ----- NetBox filters -----
# Devices that match ALL non-empty filters below get added to this group.
# Array fields (TAG, SITE, LOCATION, TENANT) accept comma-separated values;
# any device matching ANY of the listed values for a given field qualifies.
# Single-value fields (ROLE, STATUS) match exactly. Leave a field blank to
# omit it from the NetBox query.
NETBOX_TAG=snmp-cisco
NETBOX_SITE=
NETBOX_LOCATION=
NETBOX_TENANT=
NETBOX_ROLE=
NETBOX_STATUS=active

# Which IP address ktranslate should poll on each NetBox device.
# Either "primary" (primary_ip on the device) or "oob" (out-of-band IP).
NETBOX_IP_TO_PICK=primary

# Host ports for this group. Must be unique across all groups.
METALISTEN_PORT=9997
TRAP_PORT=1620

# Discovery and polling tuning.
DISCOVERY_THREADS=4
POLL_INTERVAL_SEC=60
